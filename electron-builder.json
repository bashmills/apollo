{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.bashmills.apollo",
  "icon": "resources/apollo.png",
  "asar": true,
  "asarUnpack": ["node_modules/sharp/**/*", "node_modules/@img/**/*"],
  "productName": "Apollo",
  "directories": {
    "output": "builds/${version}"
  },
  "files": ["dist-electron/**/*", "dist/**/*"],
  "linux": {
    "extraResources": [{ "from": "resources/linux/bin", "to": "bin" }],
    "artifactName": "${productName}-Linux-${version}.${ext}",
    "target": ["AppImage"],
    "category": "Audio"
  },
  "mac": {
    "extraResources": [{ "from": "resources/darwin/bin", "to": "bin" }],
    "artifactName": "${productName}-Mac-${version}.${ext}",
    "target": ["dmg"]
  },
  "win": {
    "extraResources": [{ "from": "resources/win/bin", "to": "bin" }],
    "artifactName": "${productName}-Win-${version}.${ext}",
    "target": ["msi"]
  }
}
